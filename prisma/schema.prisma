generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}


model User {
  id            String         @id @default(uuid())
  name          String
  email         String         @unique
  password      String
  role          Role
  managerId     String?
  status        UserStatus     @default(ACTIVE)
  requestedById String?
  approvedById  String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  activityLogs  ActivityLog[]
  comments      Comment[]
  notifications Notification[]
  notes         Note[]
  assignedTasks Task[]         @relation("TaskAssignedTo")
  manager       User?          @relation("ManagerToEmployees", fields: [managerId], references: [id])
  employees     User[]         @relation("ManagerToEmployees")
  
  requestedBy   User?          @relation("RequesterToUsers", fields: [requestedById], references: [id])
  requestedUsers User[]        @relation("RequesterToUsers")
  approvedBy    User?          @relation("ApproverToUsers", fields: [approvedById], references: [id])
  approvedUsers User[]         @relation("ApproverToUsers")

  attendance          Attendance[] @relation("UserAttendance")
  permissionsApproved Attendance[] @relation("PermissionApprover")
  sopStepsCompleted   TaskSOPStep[] @relation("SOPStepCompletedBy")

  @@map("users")
}

model Department {
  id        String     @id @default(uuid())
  name      String     @unique
  createdAt DateTime   @default(now())
  leads     Lead[]
  taskTypes TaskType[]
  tasks     Task[]

  @@map("departments")
}

model TaskType {
  id           String       @id @default(uuid())
  name         String
  departmentId String
  createdAt    DateTime     @default(now())
  leads        Lead[]
  sopTemplate  SOPTemplate?
  department   Department   @relation(fields: [departmentId], references: [id])
  tasks        Task[]

  @@map("task_types")
}

model SourceOfLead {
  id    String @id @default(uuid())
  name  String @unique
  leads Lead[]

  @@map("sources_of_lead")
}

model Lead {
  id            String         @id @default(uuid())
  leadNo        String         @unique
  date          DateTime
  sourceId      String
  leadName      String
  contactName   String?
  contactNumber String?
  email         String?
  departmentId  String
  taskTypeId    String
  remarks       String?
  status        LeadStatus     @default(NEW)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  department    Department     @relation(fields: [departmentId], references: [id])
  source        SourceOfLead   @relation(fields: [sourceId], references: [id])
  taskType      TaskType       @relation(fields: [taskTypeId], references: [id])
  tasks         Task[]
  documents     LeadDocument[]

  @@map("leads")
}

model Task {
  id             String         @id @default(uuid())
  taskNo         String         @unique
  leadId         String
  departmentId   String
  taskTypeId     String
  remarks        String?
  contactName    String?
  contactNumber  String?
  email          String?
  assignedToId   String
  status         TaskStatus     @default(NOT_YET_STARTED)
  priority       Priority       @default(REGULAR)
  startDate      DateTime?
  completionDate DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  activityLogs   ActivityLog[]
  comments       Comment[]
  sopSteps       TaskSOPStep[]
  documents      TaskDocument[]
  assignedTo     User           @relation("TaskAssignedTo", fields: [assignedToId], references: [id])
  department     Department     @relation(fields: [departmentId], references: [id])
  lead           Lead           @relation(fields: [leadId], references: [id])
  taskType       TaskType       @relation(fields: [taskTypeId], references: [id])

  @@map("tasks")
}

model SOPTemplate {
  id         String    @id @default(uuid())
  taskTypeId String    @unique
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  steps      SOPStep[]
  taskType   TaskType  @relation(fields: [taskTypeId], references: [id])

  @@map("sop_templates")
}

model SOPStep {
  id            String      @id @default(uuid())
  title         String
  order         Int
  assignedRole  Role        @default(EMPLOYEE)
  deadlineHours Int         @default(0)
  templateId    String
  template      SOPTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@map("sop_steps")
}

model TaskSOPStep {
  id            String    @id @default(uuid())
  taskId        String
  title         String
  order         Int
  isCompleted   Boolean   @default(false)
  completedAt   DateTime?
  completedById String?
  assignedRole  Role      @default(EMPLOYEE)
  deadlineHours Int       @default(0)
  dueAt         DateTime?
  createdAt     DateTime  @default(now())
  task          Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  completedBy   User?     @relation("SOPStepCompletedBy", fields: [completedById], references: [id])

  @@map("task_sop_steps")
}

model ActivityLog {
  id        String   @id @default(uuid())
  userId    String
  taskId    String?
  action    String
  message   String?
  createdAt DateTime @default(now())
  task      Task?    @relation(fields: [taskId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@map("activity_logs")
}

model Comment {
  id        String   @id @default(uuid())
  content   String
  userId    String
  taskId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@map("comments")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  isRead    Boolean  @default(false)
  type      String?
  link      String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@map("notifications")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  MANAGER
  EMPLOYEE
}

enum UserStatus {
  ACTIVE
  PENDING
  REJECTED
}

enum LeadStatus {
  NEW
  CONVERTED
  HOLD_BY_LEAD
  NOT_RESPONDED
  DROPPED
  AWAITING_CONFIRMATION
  MEETING_SCHEDULED
}

enum TaskStatus {
  NOT_YET_STARTED
  DATA_NOT_RECEIVED
  WORK_IN_PROGRESS
  PENDING_FOR_APPROVAL
  COMPLETED
}

enum Priority {
  REGULAR
  IMPORTANT
  URGENT
}

model Attendance {
  id                     String           @id @default(uuid())
  userId                 String
  date                   DateTime         @db.Date
  status                 AttendanceStatus @default(NOT_MARKED)
  checkIn                DateTime?
  checkOut               DateTime?
  totalHours             Float?
  morningPlan            String?
  afternoonPlan          String?
  dayCompletion          String?
  permission             PermissionStatus @default(NONE)
  permissionType         PermissionType?
  permissionReason       String?
  remarks                String?
  permissionApprovedById String?
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt

  user                 User  @relation("UserAttendance", fields: [userId], references: [id])
  permissionApprovedBy User? @relation("PermissionApprover", fields: [permissionApprovedById], references: [id])

  @@unique([userId, date])
  @@map("attendance")
}

enum AttendanceStatus {
  NOT_MARKED
  PRESENT
  ABSENT
  LATE
  HALF_DAY
  LEAVE
  SUNDAY
}

enum PermissionStatus {
  NONE
  PENDING
  APPROVED
  REJECTED
}

enum PermissionType {
  HALF_DAY
  LEAVE
  LATE_PERMISSION
}

model Note {
  id        String   @id @default(uuid())
  userId    String
  title     String?
  content   String
  color     String?  @default("blue")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])

  @@map("notes")
}

model SystemConfig {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("system_configs")
}

enum DocumentCategory {
  AADHAR
  PAN
  GST
  PHOTO
  OTHER
}

model LeadDocument {
  id           String           @id @default(uuid())
  leadId       String
  category     DocumentCategory
  originalName String
  savedName    String
  filePath     String
  mimeType     String
  size         Int
  uploadedAt   DateTime         @default(now())
  lead         Lead             @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("lead_documents")
}

model TaskDocument {
  id           String   @id @default(uuid())
  taskId       String
  originalName String
  savedName    String
  filePath     String
  mimeType     String
  size         Int
  uploadedAt   DateTime @default(now())
  task         Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("task_documents")
}
