# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
BACKEND_URL=http://localhost:5000/api

# ─── Database ─────────────────────────────────────────────────────────────────
# Local Docker PostgreSQL
DATABASE_URL="postgresql://crm_user:crm_pass@localhost:5432/crm_db"
# Direct URL (same as DATABASE_URL for local Docker - no connection pooler)
DIRECT_URL="postgresql://crm_user:crm_pass@localhost:5432/crm_db"

# Connect to Supabase via connection pooling (uncomment when deploying)
# DATABASE_URL="postgresql://postgres.ywpkhdixkcswjpxeynsi:wahid1014129@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres.ywpkhdixkcswjpxeynsi:wahid1014129@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres"
# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_key_change_me_in_production
JWT_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000